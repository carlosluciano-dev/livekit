# syntax=docker/dockerfile:1
# ---- Development Dockerfile ----
# Does NOT require uv.lock – resolves dependencies at build time.

ARG PYTHON_VERSION=3.13
FROM ghcr.io/astral-sh/uv:python${PYTHON_VERSION}-bookworm-slim

ENV PYTHONUNBUFFERED=1

# Build tools for native extensions + PortAudio for console mode
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    python3-dev \
    libportaudio2 \
    pulseaudio-utils \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy only dependency spec first (layer cache)
COPY pyproject.toml ./
RUN mkdir -p src tests

# Install deps (no lock file required in dev)
RUN uv sync --group dev

# Copy the rest of the project
COPY . .

# Pre-download Silero VAD, turn detector and noise-cancellation models
RUN uv run src/agent.py download-files

# Default: run agent in dev mode
CMD ["uv", "run", "src/agent.py", "dev"]
